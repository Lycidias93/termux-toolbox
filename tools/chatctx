#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root"

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
toolbox_root="${WORKFLOW_TOOLBOX_ROOT:-$(cd "$script_dir/.." && pwd -P)}"
registry="$toolbox_root/config/workflow-scopes.tsv"
tab="$(printf "\t")"

need_file() {
  local path="$1"
  if [[ ! -s "$path" ]]; then
    printf "ERROR: missing_or_empty %s\n" "$path" >&2
    exit 3
  fi
}

need_file "$registry"

workflow_scope_list() {
  local first=1
  local row_scope row_class row_pack row_card row_host row_route
  while IFS="$tab" read -r row_scope row_class row_pack row_card row_host row_route; do
    if [[ "$first" == "1" ]]; then
      first=0
      continue
    fi
    [[ -n "$row_scope" ]] || continue
    printf "%s\n" "$row_scope"
  done < "$registry"
}

scope_requested="${1:-repo}"
scope="${scope_requested,,}"

case "$scope" in
  --list|-l)
    workflow_scope_list
    printf "%s\n" "RESULT: CHATCTX_LIST_DONE rc=0"
    exit 0
    ;;
  repo-maintenance|maintenance) scope="repo" ;;
  generic-repo) scope="generic" ;;
  workflow|baseline) scope="workflow-baseline" ;;
esac

found=0
scope_class=""
pack=""
card=""
scope_host=""
route_hint=""
first=1
while IFS="$tab" read -r row_scope row_class row_pack row_card row_host row_route; do
  if [[ "$first" == "1" ]]; then
    first=0
    continue
  fi
  if [[ "$row_scope" == "$scope" ]]; then
    scope_class="$row_class"
    pack="$row_pack"
    card="$row_card"
    scope_host="$row_host"
    route_hint="$row_route"
    found=1
    break
  fi
done < "$registry"

if [[ "$found" != "1" ]]; then
  printf "ERROR: unknown scope: %s\n" "$scope_requested" >&2
  printf "%s\n" "Supported scopes:" >&2
  workflow_scope_list >&2
  exit 2
fi

resolve_file() {
  local rel="$1"
  if [[ -s "$repo_root/$rel" ]]; then
    printf "%s\n" "$repo_root/$rel"
  elif [[ -s "$toolbox_root/$rel" ]]; then
    printf "%s\n" "$toolbox_root/$rel"
  else
    printf "%s\n" "$repo_root/$rel"
  fi
}

pack_path="$(resolve_file "$pack")"
card_path="$(resolve_file "$card")"
template_path="$(resolve_file templates/state_gate.md)"
need_file "$pack_path"
need_file "$card_path"
need_file "$template_path"

printf "%s\n" "STATE-GATE INPUT"
printf "generated_at=%s\n" "$(date -Is)"
printf "repo_root=%s\n" "$repo_root"
printf "toolbox_root=%s\n" "$toolbox_root"
printf "scope_requested=%s\n" "$scope_requested"
printf "scope=%s\n" "$scope"
printf "scope_class=%s\n" "$scope_class"
printf "scope_host=%s\n" "$scope_host"
printf "route_hint=%s\n" "$route_hint"
printf "\n"

printf "%s\n" "== git =="
git branch --show-current 2>/dev/null | sed "s/^/branch=/" || true
git log -1 --oneline 2>/dev/null | sed "s/^/head=/" || true
git status --short 2>/dev/null | sed "s/^/status=/" || true
printf "\n"

printf "== context pack: %s ==\n" "$pack"
sed -n "1,220p" "$pack_path"
printf "\n"

printf "== task card: %s ==\n" "$card"
sed -n "1,220p" "$card_path"
printf "\n"

printf "%s\n" "== state gate template =="
sed -n "1,160p" "$template_path"
printf "\n"

printf "%s\n" "RESULT: CHATCTX_DONE rc=0"
