#!/usr/bin/env bash
set -Eeuo pipefail

on_err() {
  local rc="$?"
  printf 'RESULT: CGFLOW_FAIL rc=%s\n' "$rc"
  exit "$rc"
}
trap on_err ERR

say() { printf '%s\n' "$*"; }
fail() { printf 'FAIL: %s\n' "$*" >&2; exit 1; }
pass() { printf 'PASS: %s\n' "$*"; }

usage() {
  printf '%s\n' 'Usage: tools/cgflow <scope> <mode> <artifact-or-none>'
  printf '%s\n' 'Scopes: repo generic workflow-baseline'
  printf '%s\n' 'Modes: verify-only repo-doc repo-code artifact-python artifact-bash multi-repo'
}

scope="${1:-}"
mode="${2:-}"
artifact="${3:-none}"

if [[ -z "$scope" || -z "$mode" ]]; then
  usage
  fail 'missing_scope_or_mode'
fi

case "${scope,,}" in
  repo|generic|workflow-baseline|workflow|baseline) ;;
  *) fail "unknown_scope=$scope" ;;
esac

case "$mode" in
  verify-only|repo-doc|repo-code|artifact-python|artifact-bash|multi-repo) ;;
  *) fail "unknown_mode=$mode" ;;
esac

state_gate_decision="${HEIMNETZ_STATE_GATE_DECISION:-}"
case "$mode" in
  verify-only) ;;
  repo-doc)
    if [[ "$state_gate_decision" != 'GO' && "$state_gate_decision" != 'DOC-ONLY' ]]; then
      fail 'repo-doc_requires_state_gate_GO_or_DOC_ONLY'
    fi
    ;;
  repo-code|artifact-python|artifact-bash|multi-repo)
    if [[ "$state_gate_decision" != 'GO' ]]; then
      fail 'mode_requires_state_gate_GO'
    fi
    ;;
esac

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root"

say '== cgflow =='
say "time=$(date -Is)"
say "repo_root=$repo_root"
say "scope=$scope"
say "mode=$mode"
say "artifact=$artifact"
say "state_gate_decision=${state_gate_decision:-unset}"
say "routeguard_ack=${HEIMNETZ_ROUTEGUARD_ACK:-0}"
say

[[ -x tools/chatctx ]] || fail 'tools/chatctx_missing_or_not_executable'
tools/chatctx "$scope"
pass "chatctx_scope $scope"

check_lf() {
  local path="$1"
  [[ -f "$path" ]] || fail "missing_file=$path"
  if LC_ALL=C grep -q $'\r' "$path"; then
    fail "crlf_present=$path"
  fi
  pass "lf_only $path"
}

check_bash_script() {
  local path="$1"
  [[ -s "$path" ]] || fail "missing_or_empty=$path"
  check_lf "$path"
  local first=''
  first="$(sed -n '1p' "$path")"
  [[ "$first" == '#!/usr/bin/env bash' ]] || fail "shebang_wrong=$path"
  [[ -x "$path" ]] || fail "not_executable=$path"
  bash -n "$path"
  pass "bash_syntax $path"
  local lt='<'; local hd="${lt}${lt}"; local hs="${lt}${lt}${lt}"
  if LC_ALL=C grep -Fq "$hd" "$path" || LC_ALL=C grep -Fq "$hs" "$path"; then
    fail "heredoc_or_herestring_present=$path"
  fi
  pass "no_heredoc_herestring $path"
}

check_bash_script tools/chatctx
check_bash_script tools/cgflow

if [[ -x tools/secret-guard.sh ]]; then
  tools/secret-guard.sh all
  pass 'secret_guard_all'
else
  pass 'secret_guard_absent_allowed_for_generic_repo'
fi

if [[ -x tools/route-change-guard.sh ]]; then
  HEIMNETZ_ROUTEGUARD_ACK="${HEIMNETZ_ROUTEGUARD_ACK:-0}" tools/route-change-guard.sh all
  pass 'route_change_guard_all'
else
  pass 'route_change_guard_absent_allowed_for_generic_repo'
fi

case "$mode" in
  artifact-python)
    command -v python3 >/dev/null 2>&1 || fail 'python3_missing'
    [[ -s "$artifact" ]] || fail "artifact_missing_or_empty=$artifact"
    check_lf "$artifact"
    python3 -m py_compile "$artifact"
    pass "python_compile $artifact"
    ;;
  artifact-bash)
    check_bash_script "$artifact"
    ;;
  multi-repo)
    [[ -f WORKFLOW_BASELINE.md || -f WORKFLOW_TOOLBOX.md ]] || fail 'workflow_baseline_doc_missing'
    pass 'multi_repo_baseline_doc_present'
    ;;
  verify-only|repo-doc|repo-code)
    pass "mode_preflight $mode"
    ;;
esac

if git diff --check; then
  pass 'git_diff_check'
else
  fail 'git_diff_check'
fi

say 'RESULT: CGFLOW_PASS rc=0'
